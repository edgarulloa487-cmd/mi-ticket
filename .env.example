# Copiar a .env y rellenar con los valores del proyecto Supabase
# (Dashboard → Project Settings → API).
#
# La publishable key está pensada para vivir en el navegador: no es un secreto.
# Lo que protege los datos es la RLS, no esconder esta llave.
# La que NUNCA va aquí ni en el cliente es la service_role: es una llave maestra
# que se salta la RLS por completo.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
